{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build-engine": {
      "dependsOn": [
        "^build-engine"
      ]
    },
    "download-icons": {
      "dependsOn": [
        "^download-icons"
      ]
    },
    "build": {
      "cache": true
    },
    "test": {
      "cache": true,
      "inputs": [
        "default",
        "^default"
      ],
      "outputs": [
        "{projectRoot}/coverage"
      ]
    }
  },
  "release": {
    "projects": ["packages/*"],
    "projectsRelationship": "fixed",
    "version": {
      "currentVersionResolver": "git-tag"
    },
    "changelog": {
      "workspaceChangelog": {
        "createRelease": "github"
      },
      "projectChangelogs": true
    }
  },
  "plugins": [
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    }
  ]
}
