{
  "name": "@k-4u/resource-mapper-shared",
  "version": "0.3.0",
  "description": "Shared types and validators for the resource-mapper toolchain",
  "keywords": [
    "architecture",
    "types",
    "validators",
    "yaml"
  ],
  "author": "K-4U",
  "homepage": "https://github.com/K-4U/resource-mapper#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/K-4U/resource-mapper.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/K-4U/resource-mapper/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./flow-types": {
      "types": "./dist/flow-types.d.ts",
      "default": "./dist/flow-types.js"
    },
    "./validators": {
      "types": "./dist/validators.d.ts",
      "default": "./dist/validators.js"
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "node -e \"const fs=require('fs');fs.copyFileSync('../../LICENSE','LICENSE');\" && npm run build"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
