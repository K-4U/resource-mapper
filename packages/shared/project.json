{
  "name": "shared",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/shared/vitest.config.ts"
      },
      "outputs": ["{projectRoot}/coverage"]
    },
    "publish": {
      "command": "npm publish --access public",
      "dependsOn": ["build"]
    }
  }
}