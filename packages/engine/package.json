{
  "name": "@k-4u/resource-mapper",
  "version": "0.3.0",
  "description": "CLI tool to bake and visualise your architecture as an interactive map",
  "keywords": [
    "architecture",
    "visualisation",
    "diagram",
    "cli",
    "yaml"
  ],
  "author": "K-4U",
  "homepage": "https://github.com/K-4U/resource-mapper#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/K-4U/resource-mapper.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/K-4U/resource-mapper/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "@k-4u/resource-mapper-shared": "*",
    "@k-4u/resource-mapper-core": "*",
    "execa": "^9.6.1",
    "zod": "^4.3.6"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "../../README.md",
    "../../LICENSE"
  ],
  "bin": {
    "mapper-engine": "./dist/cli.js"
  },
  "scripts": {
    "build-engine": "tsup",
    "download-icons": "node src/scripts/download-aws-icons.ts",
    "prepublishOnly": "cp ../../README.md . && cp ../../LICENSE . && npm run build-engine"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "chokidar": "^5.0.0"
  }
}
