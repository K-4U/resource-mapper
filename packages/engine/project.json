{
  "name": "engine",
  "projectType": "application",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "packages/engine"
      }
    },
    "test-coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --coverage",
        "cwd": "packages/engine"
      }
    },
    "publish": {
      "command": "npm publish --access public",
      "dependsOn": ["build"]
    }
  }
}