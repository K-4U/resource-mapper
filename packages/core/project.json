{
  "name": "core",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      },
      "outputs": ["{projectRoot}/build"],
      "dependsOn": [{ "projects": "shared", "target": "build" }]
    },
    "dev": {
      "executor": "nx:run-script",
      "options": {
        "script": "dev"
      },
      "dependsOn": [{ "projects": "shared", "target": "build" }]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "packages/core"
      },
      "configurations": {
        "coverage": {
          "command": "vitest run --coverage"
        }
      },
      "outputs": ["{projectRoot}/coverage"]
    },
    "publish": {
      "command": "npm publish --access public",
      "dependsOn": ["build"]
    }
  }
}